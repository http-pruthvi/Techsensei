{
  "name": "techsensei-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for TechSensei AI Learning Platform",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "serve-all": "npm run build && firebase emulators:start --only functions,auth,firestore,storage",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "dev": "npm run serve",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
